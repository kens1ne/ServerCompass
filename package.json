{
  "name": "servercompass",
  "version": "1.15.6",
  "description": "Server Compass - Navigate your server infrastructure with ease. Offline-first desktop app for managing virtual private servers",
  "main": "dist-electron/electron/main.js",
  "author": {
    "name": "ServerCompass",
    "email": "hello@stoicsoft.com"
  },
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "build:mac": "electron-builder --mac dmg",
    "build:mac:dir": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.stoicsoft.servercompass",
    "productName": "ServerCompass",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**",
      "node_modules/keytar/**",
      "node_modules/ssh2/**"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/lib-storage": "^3.995.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@octokit/rest": "^22.0.1",
    "@sentry/electron": "^7.2.0",
    "@sentry/react": "^10.25.0",
    "@smithy/node-http-handler": "^4.4.10",
    "@tanstack/react-query": "^5.90.5",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.24",
    "keytar": "^7.9.0",
    "libsodium-wrappers": "^0.7.15",
    "lucide-react": "^0.548.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.4",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "yaml": "^2.8.2",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "electron": "38.8.4",
    "electron-builder": "^26.8.1",
    "node-abi": "^4.26.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  }
}